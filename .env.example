# ---- Client (Vite, public) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
VITE_SUPABASE_PROJECT_ID=your-project-ref

# ---- Server (runtime only — never expose to client) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Precoro
PRECORO_API_TOKEN=

# Xero OAuth2
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://your-domain.com/api/xero/callback

# Azure AI Foundry (optional — used for AI search / item matching)
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_ENDPOINT=

# Webhook signing secret (Precoro / external callbacks)
WEBHOOK_SECRET=